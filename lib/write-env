#!/bin/bash

set -e

cd "`dirname "$0"`/.."

(
    echo '# Warning: Do not edit this file directly. All changes will be overriden.'
    echo '# To override this file, edit bin/docker-entrypoint and put proper environment'
    echo '# variables here.'
    echo
    envfile -o - -r .env
) > .env.local

bash -c '
    source .env
    source .env.local
    if [ "$APP_ENV" = "prod" ]; then
        composer dump-env
    else
        rm -f .env.local.php
    fi
'
